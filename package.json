{
  "name": "pinball-wizard",
  "version": "1.0.0",
  "scripts": {
    "test": "npx vite build --config vite.config.prod.ts && npx mocha",
    "dev": "vite --config vite.config.ts",
    "dev:static": "concurrently \"npx vite build --watch\" \"npx serve dist\"",
    "build:prod": "vite build --config vite.config.prod.ts && npx mocha && npm run zip",
    "build:quickprod": "vite build --config vite.config.prod.ts && npm run zip",
    "zip": "cp -r reports dist && cd dist && zip -r woo-pong.zip .",
    "build": "npm run build-starts && npm run build-rooms && npm run build-blobs",
    "build-blobs": "ts-node -r tsconfig-paths/register build/build-blobs.ts",
    "build-rooms": "ts-node -r tsconfig-paths/register build/build-room-layouts.ts",
    "build-starts": "ts-node -r tsconfig-paths/register build/build-start-layouts.ts",
    "build-cover": "ts-node -r tsconfig-paths/register build/build-cover.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@eslint/js": "^9.29.0",
    "@stylistic/eslint-plugin": "^5.1.0",
    "@types/archiver": "^7.0.0",
    "@types/expect": "^1.20.4",
    "@types/howler": "^2.2.12",
    "@types/jsdom": "^27.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.183.1",
    "@typescript-eslint/rule-tester": "^8.34.1",
    "@typescript-eslint/utils": "^8.34.1",
    "archiver": "^7.0.1",
    "canvas": "^3.2.0",
    "compression": "^1.8.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.29.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^51.0.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gl": "^8.1.6",
    "glob": "^11.0.3",
    "jiti": "^2.4.2",
    "jsdom": "^27.0.0",
    "jsdom-global": "3.0.2",
    "minimatch": "^10.2.4",
    "mocha": "^11.3.0",
    "patch-package": "^8.0.0",
    "path-to-regexp": "^8.3.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.32.0",
    "serve": "^13.0.4",
    "serve-handler": "^1.0.0",
    "three": "^0.183.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vite-plugin-glsl": "^1.5.5",
    "vite-plugin-json5": "^1.1.9",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "lil-gui": "^0.20.0",
    "points-on-path": "^0.2.1"
  },
  "optionalDependencies": {
    "demo-tests": "file:../demo-tests"
  }
}
